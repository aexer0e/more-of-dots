# Desktop backend / optional diagnostic server
WOD_HOST=127.0.0.1
WOD_PORT=8787
WOD_MAX_REPLAY_BYTES=20971520
WOD_MAX_REPLAY_JSON_BYTES=104857600
WOD_CAPTURE_SAMPLE_HZ=10
WOD_CAPTURE_TIMEOUT_SECONDS=1800
# Optional fixed capture window. Leave blank to capture until replay end or timeout.
WOD_LIVE_CAPTURE_SECONDS=
WOD_LIVE_SIM_SPEED=120
WOD_LIVE_REPLAY_SAMPLE_HZ=2
WOD_LIVE_MAX_SAMPLE_TICK_GAP=15
WOD_LIVE_CAPTURE_THROTTLE_SECONDS=0
WOD_LIVE_FAST_FORWARD_CONTROLLER=true
WOD_LIVE_FAST_FORWARD_STEP_METHOD=game-update
# auto, game-live-python, memory, or replay-file-dev
WOD_CAPTURE_SOURCE=auto
WOD_ADDRESS_PROFILE_DIR=runtime\address-profiles
WOD_RUNNER_SMOKE_REQUIRED=false

# Steam / staging
WOD_STEAM_GAME_DIR=C:\Program Files (x86)\Steam\steamapps\common\War of Dots
WOD_RUNTIME_DIR=runtime

# Local logged-in runner
WOD_LOCAL_RUNNER_SCRIPT=scripts\local-runner.ps1
WOD_GAME_WINDOW_TITLE=War of Dots
WOD_GAME_DESKTOP_STRATEGY=automation-desktop
WOD_GAME_WINDOW_STRATEGY=offscreen
