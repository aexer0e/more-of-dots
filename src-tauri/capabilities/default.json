{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window permissions",
  "windows": ["main", "replayPlayer", "replay-player-*"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/wod-replay-server",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
